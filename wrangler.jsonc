{
  "name": "blog",
  "compatibility_date": "2026-04-16", // Update to the day you deploy
  "assets": {
    "directory": "./dist"
  },
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  },
  "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1
    }
}